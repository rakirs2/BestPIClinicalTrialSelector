<nav class="nav-shell">
    <div class="brand-row">
        <a class="navbar-brand" href="">Best PI Selector</a>
        <button type="button"
                class="navbar-toggler"
                @onclick="ToggleNav"
                aria-label="Toggle navigation"
                aria-expanded="@_isNavOpen">
            <span></span><span></span><span></span>
        </button>
    </div>

    <div class="nav-scrollable @( _isNavOpen ? "open" : null )">
        <nav class="nav flex-column">
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="" Match="NavLinkMatch.All" @onclick="CloseNav">
                    Home
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="db-health" @onclick="CloseNav">
                    DB Health
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="scraper-status" @onclick="CloseNav">
                    Scraper Status
                </NavLink>
            </div>
        </nav>
    </div>
</nav>

@code {
    private bool _isNavOpen;

    private void ToggleNav()
    {
        _isNavOpen = !_isNavOpen;
    }

    private void CloseNav()
    {
        _isNavOpen = false;
    }
}
