@using BestPI.Frontend.Services
@inject ThemeService ThemeService

<div class="theme-toggle">
    <label for="theme-select">Appearance</label>
    <select id="theme-select" class="theme-select" @onchange="OnThemeChanged" value="@_currentValue">
        <option value="system">System</option>
        <option value="light">Light</option>
        <option value="dark">Dark</option>
    </select>
</div>

@code {
    private string _currentValue = ThemePreference.System.ToString().ToLowerInvariant();
    private bool _ready;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _ready)
        {
            return;
        }

        await ThemeService.InitializeAsync();
        _currentValue = ThemeService.Current.ToString().ToLowerInvariant();
        _ready = true;
        StateHasChanged();
    }

    private async Task OnThemeChanged(ChangeEventArgs args)
    {
        if (args.Value is not string raw)
        {
            return;
        }

        if (!Enum.TryParse<ThemePreference>(raw, true, out var preference))
        {
            return;
        }

        _currentValue = raw.ToLowerInvariant();

        if (_ready)
        {
            await ThemeService.SetThemeAsync(preference);
        }
    }
}
