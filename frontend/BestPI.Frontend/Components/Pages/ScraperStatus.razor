@page "/scraper-status"
@using System.Net.Http.Json
@using System.Threading
@using BestPI.Frontend.Services
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation
@implements IAsyncDisposable

<PageTitle>Scraper Status</PageTitle>

<div class="scraper-page">
    <header>
        <div>
            <p class="eyebrow">Ingestion Pipeline</p>
            <h1>ClinicalTrials.gov Scraper Status</h1>
            <p>Track the most recent ingest run and review historical executions.</p>
        </div>
        <button class="refresh" @onclick="RefreshAsync" disabled="@_isRefreshing">
            @_isRefreshing ? "Refreshing" : "Refresh"
        </button>
    </header>

    @if (_error is not null)
    {
        <div class="error-banner">
            <strong>Unable to load scraper status.</strong>
            <span>@_error</span>
        </div>
    }
    else if (_status is null)
    {
        <p class="muted">Loading scraper history…</p>
    }
    else
    {
        <section class="latest-card card-surface">
            <div class="latest-header">
                <div>
                    <p class="eyebrow">Latest Run</p>
                    <h2>@(_status.LatestRun is null ? "No runs recorded" : _status.LatestRun.StartedAt.ToLocalTime().ToString("g"))</h2>
                </div>
                <div class="pill-group">
                    @if (_status.LatestRun is not null)
                    {
                        <span class="status-pill @GetStatusClass(_status.LatestRun.Status)">@FormatStatus(_status.LatestRun.Status)</span>
                    }
                </div>
            </div>

            @if (_status.LatestRun is not null)
            {
                <dl class="latest-grid">
                    <div>
                        <dt>Processed</dt>
                        <dd>@_status.LatestRun.ProcessedCount</dd>
                    </div>
                    <div>
                        <dt>Chunk</dt>
                        <dd>@_status.LatestRun.CurrentChunk</dd>
                    </div>
                    <div>
                        <dt>Last Token</dt>
                        <dd>@(_status.LatestRun.LastPageToken ?? "-")</dd>
                    </div>
                    <div>
                        <dt>Finish</dt>
                        <dd>@(_status.LatestRun.FinishedAt?.ToLocalTime().ToString("g") ?? "In progress")</dd>
                    </div>
                </dl>

                @if (!string.IsNullOrWhiteSpace(_status.LatestRun.Notes))
                {
                    <p class="notes">Notes: @_status.LatestRun.Notes</p>
                }
                @if (!string.IsNullOrWhiteSpace(_status.LatestRun.LastError))
                {
                    <p class="error-text">Last error: @_status.LatestRun.LastError</p>
                }
            }
            else
            {
                <p class="muted">Run the scraper to populate this section.</p>
            }
        </section>

        <section>
            <div class="table-header">
                <h3>History</h3>
                <small>Updated @(_status.RetrievedAt.ToLocalTime().ToString("g"))</small>
            </div>
            <div class="table-wrapper">
                <table>
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Status</th>
                            <th>Processed</th>
                            <th>Chunk</th>
                            <th>Started</th>
                            <th>Finished</th>
                            <th>Notes</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var run in _status.RecentRuns)
                        {
                            <tr>
                                <td>@run.Id.ToString()[..8]</td>
                                <td><span class="status-pill @GetStatusClass(run.Status)">@FormatStatus(run.Status)</span></td>
                                <td>@run.ProcessedCount</td>
                                <td>@run.CurrentChunk</td>
                                <td>@run.StartedAt.ToLocalTime().ToString("g")</td>
                                <td>@(run.FinishedAt?.ToLocalTime().ToString("g") ?? "-")</td>
                                <td>@(string.IsNullOrWhiteSpace(run.Notes) ? "" : run.Notes)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>

        <section class="logs-card card-surface">
            <div class="table-header">
                <h3>Live Logs</h3>
                <small>@((_status.LatestRunLogs?.Count ?? 0) == 0 ? "No log entries yet" : "Most recent 50 entries")</small>
            </div>
            <div class="log-list">
                @if (_status.LatestRunLogs is null || _status.LatestRunLogs.Count == 0)
                {
                    <p class="muted">Logs will appear here while the scraper is running.</p>
                }
                else
                {
                    @foreach (var log in _status.LatestRunLogs)
                    {
                        <div class="log-entry">
                            <span class="log-time">@log.LoggedAt.ToLocalTime().ToString("HH:mm:ss")</span>
                            <span class="log-level @log.Level.ToLowerInvariant()">@log.Level</span>
                            <span class="log-message">@log.Message</span>
                        </div>
                    }
                }
            </div>
        </section>
    }
</div>

@code {
    private readonly TimeSpan _refreshInterval = TimeSpan.FromSeconds(30);
    private ScraperStatusSnapshot? _status;
    private string? _error;
    private bool _isRefreshing;
    private HttpClient? _httpClient;
    private PeriodicTimer? _timer;
    private CancellationTokenSource? _timerCts;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
        _timerCts = new CancellationTokenSource();
        _timer = new PeriodicTimer(_refreshInterval);
        _ = RunRefreshLoopAsync();
    }

    private async Task RunRefreshLoopAsync()
    {
        if (_timer is null || _timerCts is null)
        {
            return;
        }

        try
        {
            while (await _timer.WaitForNextTickAsync(_timerCts.Token))
            {
                await RefreshAsync();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
            // ignore
        }
    }

    private async Task RefreshAsync()
    {
        if (_isRefreshing)
        {
            return;
        }

        _isRefreshing = true;
        _error = null;

        try
        {
            var client = EnsureHttpClient();
            _status = await client.GetFromJsonAsync<ScraperStatusSnapshot>("api/scraper-status");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isRefreshing = false;
        }
    }

    private HttpClient EnsureHttpClient()
    {
        if (_httpClient is not null)
        {
            return _httpClient;
        }

        var client = HttpClientFactory.CreateClient();
        client.BaseAddress ??= new Uri(Navigation.BaseUri);
        _httpClient = client;
        return client;
    }

    private static string GetStatusClass(string status) => status switch
    {
        "failed" => "critical",
        "stopped_threshold" => "warning",
        "stopped_manual" => "warning",
        "running" => "healthy",
        _ => "healthy"
    };

    private static string FormatStatus(string status) => ScraperStatusFormatting.ToDisplayLabel(status);

    public async ValueTask DisposeAsync()
    {
        _timerCts?.Cancel();
        if (_timer is not null)
        {
            _timer.Dispose();
        }

        if (_timerCts is not null)
        {
            await Task.Yield();
            _timerCts.Dispose();
        }
    }
}
