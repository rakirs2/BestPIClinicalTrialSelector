@page "/db-health"
@using System.Net.Http.Json
@using System.Threading
@using BestPI.Frontend.Services
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation
@implements IAsyncDisposable

<PageTitle>Database Health</PageTitle>

<div class="health-page">
    <header>
        <div>
            <p class="eyebrow">Operational Metrics</p>
            <h1>PostgreSQL Health Overview</h1>
            <p>Live statistics pulled directly from the ingestion database. Updates every 30 seconds.</p>
        </div>
        <button class="refresh" @onclick="RefreshAsync" disabled="@_isRefreshing">
            @_isRefreshing ? "Refreshing" : "Refresh"
        </button>
    </header>

    @if (_error is not null)
    {
        <div class="error-banner">
            <strong>Unable to load DB metrics.</strong>
            <span>@_error</span>
        </div>
    }
    else if (_health is null)
    {
        <p class="muted">Loading database metrics…</p>
    }
    else
    {
        if (!string.IsNullOrWhiteSpace(_health.Error))
        {
            <div class="error-banner subtle">
                <strong>Database connection error:</strong>
                <span>@_health.Error</span>
            </div>
        }

        <section class="metrics-grid">
            <article class="metric-card">
                <header>
                    <span>Status</span>
                    <span class="status-pill @GetStatusClass(_health.Status)">@_health.Status.ToUpperInvariant()</span>
                </header>
                <p class="value">@_health.SizePretty</p>
                <small>@string.Format("{0:N0} bytes", _health.SizeBytes)</small>
            </article>

            <article class="metric-card">
                <header>
                    <span>Uptime</span>
                </header>
                <p class="value">@FormatDuration(_health.UptimeSeconds)</p>
                <small>Checked @(_health.CheckedAt.ToLocalTime().ToString("g"))</small>
            </article>

            <article class="metric-card">
                <header>
                    <span>Connections</span>
                </header>
                <p class="value">@_health.Connections / @_health.MaxConnections</p>
                <small>@_health.ConnectionUtilization% utilization</small>
            </article>

            <article class="metric-card">
                <header>
                    <span>Maintenance</span>
                </header>
                <p class="value">@(_health.LastVacuum?.ToLocalTime().ToString("g") ?? "n/a")</p>
                <small>Last vacuum/autovacuum</small>
            </article>
        </section>
    }
</div>

@code {
    private readonly TimeSpan _refreshInterval = TimeSpan.FromSeconds(30);
    private DbHealthSnapshot? _health;
    private string? _error;
    private bool _isRefreshing;
    private HttpClient? _httpClient;
    private PeriodicTimer? _timer;
    private CancellationTokenSource? _timerCts;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
        _timerCts = new CancellationTokenSource();
        _timer = new PeriodicTimer(_refreshInterval);
        _ = RunRefreshLoopAsync();
    }

    private async Task RunRefreshLoopAsync()
    {
        if (_timer is null || _timerCts is null)
        {
            return;
        }

        try
        {
            while (await _timer.WaitForNextTickAsync(_timerCts.Token))
            {
                await RefreshAsync();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
            // ignored
        }
    }

    private async Task RefreshAsync()
    {
        if (_isRefreshing)
        {
            return;
        }

        _isRefreshing = true;
        _error = null;

        try
        {
            var client = EnsureHttpClient();
            _health = await client.GetFromJsonAsync<DbHealthSnapshot>("api/db-health");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isRefreshing = false;
        }
    }

    private HttpClient EnsureHttpClient()
    {
        if (_httpClient is not null)
        {
            return _httpClient;
        }

        var client = HttpClientFactory.CreateClient();
        client.BaseAddress ??= new Uri(Navigation.BaseUri);
        _httpClient = client;
        return client;
    }

    private static string GetStatusClass(string status) => status switch
    {
        "critical" => "critical",
        "warning" => "warning",
        "unreachable" => "critical",
        _ => "healthy"
    };

    private static string FormatDuration(double seconds)
    {
        if (seconds <= 0)
        {
            return "n/a";
        }

        var ts = TimeSpan.FromSeconds(seconds);
        if (ts.TotalDays >= 1)
        {
            return $"{(int)ts.TotalDays}d {ts.Hours}h";
        }

        if (ts.TotalHours >= 1)
        {
            return $"{(int)ts.TotalHours}h {ts.Minutes}m";
        }

        return $"{ts.Minutes}m {ts.Seconds}s";
    }

    public async ValueTask DisposeAsync()
    {
        _timerCts?.Cancel();
        if (_timer is not null)
        {
            _timer.Dispose();
        }

        if (_timerCts is not null)
        {
            await Task.Yield();
            _timerCts.Dispose();
        }
    }
}
