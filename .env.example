# Copy to .env and adjust values as needed
POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/clinicaltrials
CTGOV_BASE_URL=https://clinicaltrials.gov/api/v2/studies
BATCH_SIZE=100
RATE_LIMIT_PER_SEC=3
CONCURRENCY=1
DB_SIZE_LIMIT_GB=10
LOG_LEVEL=INFO
SCRAPER_ENV=development
# Force smaller caps for non-production environments (defaults to 5 when SCRAPER_ENV!=production)
MAX_CHUNKS_DEFAULT=5
# Override cap explicitly (useful for smoke tests)
# MAX_CHUNKS=3
# Uncomment to resume most recent unfinished run automatically
# RESUME_LATEST=true
